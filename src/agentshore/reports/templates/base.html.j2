<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}AgentShore Report{% endblock %}</title>
    <style>
        /* Dark theme inspired by Tokyo Night */
        :root {
            --bg: #1a1b26;
            --bg-alt: #24283b;
            --fg: #c0caf5;
            --fg-dim: #565f89;
            --green: #9ece6a;
            --yellow: #e0af68;
            --red: #f7768e;
            --blue: #7aa2f7;
            --purple: #bb9af7;
            --cyan: #7dcfff;
            --border: #414868;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: var(--bg);
            color: var(--fg);
            font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', 'JetBrains Mono', monospace;
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
            line-height: 1.6;
        }
        h1, h2, h3 {
            color: var(--blue);
            border-bottom: 1px solid var(--border);
            padding-bottom: 0.5rem;
            margin-bottom: 1rem;
        }
        h1 { font-size: 1.8rem; margin-bottom: 1.5rem; }
        h2 { font-size: 1.3rem; }
        h3 { font-size: 1.1rem; border-bottom: none; }
        table {
            border-collapse: collapse;
            width: 100%;
            margin: 1rem 0;
            font-size: 0.9rem;
        }
        th, td {
            padding: 0.5rem 1rem;
            border: 1px solid var(--border);
            text-align: left;
        }
        th { background: var(--bg-alt); color: var(--blue); }
        tr:hover { background: rgba(65, 72, 104, 0.2); }
        .success { color: var(--green); }
        .failure { color: var(--red); }
        .warning { color: var(--yellow); }
        .chart-container { max-width: 600px; margin: 1rem 0; }
        .metric {
            display: inline-block;
            padding: 0.5rem 1rem;
            margin: 0.25rem;
            background: var(--bg-alt);
            border-radius: 4px;
            border: 1px solid var(--border);
        }
        .metric .label { color: var(--fg-dim); font-size: 0.8rem; }
        .metric .value { font-size: 1.2rem; font-weight: bold; }
        .bar {
            display: inline-block;
            height: 1.2em;
            background: var(--green);
            border-radius: 2px;
            vertical-align: middle;
        }
        .section {
            margin: 2rem 0;
            padding: 1.5rem;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: rgba(36, 40, 59, 0.3);
        }
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }
        ul, ol { padding-left: 1.5rem; margin: 0.5rem 0; }
        li { margin: 0.25rem 0; }
        code { background: var(--bg-alt); padding: 0.1rem 0.3rem; border-radius: 3px; }
        a { color: var(--blue); text-decoration: none; }
        a:hover { text-decoration: underline; }
        .empty-state { color: var(--fg-dim); font-style: italic; padding: 1rem 0; }
    </style>
    <script>{{ chart_js }}</script>
</head>
<body>
{% block content %}{% endblock %}
<footer style="margin-top:3rem;color:var(--fg-dim);text-align:center;font-size:0.8rem;">
    Generated by <a href="https://github.com/SuperSwinkAI/Swink-AgentShore">AgentShore</a>
</footer>
</body>
</html>
