{
  "name": "@agentshore/dashboard",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run --environment jsdom",
    "test:e2e": "echo 'Playwright tests are opt-in. Run: npm run ui-integrity-check' && exit 0",
    "ui-integrity-check": "UI_INTEGRITY_CHECK=1 playwright test",
    "ui-integrity-check:ci": "UI_INTEGRITY_CHECK=1 playwright test --reporter=line",
    "build:lib": "vite build --mode lib && tsc -p tsconfig.lib.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "27.4.0",
    "typescript": "5.9.3",
    "vite": "8.0.13",
    "vitest": "4.1.6",
    "ws": "8.20.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
