{
  "name": "@agentshore/dashboard",
  "private": true,
  "version": "0.9.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run --environment jsdom",
    "test:e2e": "echo 'Playwright tests are opt-in. Run: npm run ui-integrity-check' && exit 0",
    "ui-integrity-check": "UI_INTEGRITY_CHECK=1 playwright test",
    "ui-integrity-check:ci": "UI_INTEGRITY_CHECK=1 playwright test --reporter=line",
    "build:lib": "vite build --mode lib && tsc -p tsconfig.lib.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "ws": "8.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  }
}
