<?xml version="1.0" encoding="utf-8"?>
<!--
  productbuild Distribution definition for AgentShore.

  Three components are declared so the wizard's Customize panel shows them as
  deliberate user-visible choices:
    - Desktop is required (start_selected + enabled="false").
    - Timelapse is opt-in (start_selected="false") — a heavier optional
      toolchain (Homebrew ffmpeg/Node + a headless Chromium).
    - CLI is opt-out (start_selected="true").

  Outline order is install order: Desktop first (provisions the managed venv
  the Timelapse component reuses), then Timelapse, then CLI last (it owns the
  Installer auto-close in cli-postinstall).

  build-macos.sh substitutes:
    @VERSION@                  — pyproject + tauri.conf.json version string
    @APP_COMPONENT_PKG@        — filename of the desktop component pkg
    @TIMELAPSE_COMPONENT_PKG@  — filename of the timelapse component pkg
    @CLI_COMPONENT_PKG@        — filename of the CLI component pkg
-->
<installer-gui-script minSpecVersion="2">
    <title>AgentShore</title>
    <license file="EULA.rtf" mime-type="application/rtf"/>
    <options
        customize="always"
        require-scripts="false"
        hostArchitectures="arm64,x86_64"
        rootVolumeOnly="true"/>
    <volume-check>
        <allowed-os-versions>
            <os-version min="11.0"/>
        </allowed-os-versions>
    </volume-check>
    <choices-outline>
        <line choice="ai.agentshore.desktop"/>
        <line choice="ai.agentshore.timelapse"/>
        <line choice="ai.agentshore.cli"/>
    </choices-outline>
    <choice id="ai.agentshore.desktop"
            title="AgentShore Desktop"
            description="The AgentShore desktop application with bundled Python sidecar. Required."
            enabled="false"
            start_selected="true">
        <pkg-ref id="ai.agentshore.desktop"/>
    </choice>
    <choice id="ai.agentshore.timelapse"
            title="Timelapse Capture (optional)"
            description="Provisions the timelapse-capture toolchain (Homebrew ffmpeg, Node.js 24+, and the timelapse-capture CLI via npm) so the desktop can record a timelapse of the dashboard. Heavier install — downloads a headless Chromium. Leave unchecked to skip; you can install it later from the app's Start screen."
            start_selected="false">
        <pkg-ref id="ai.agentshore.timelapse"/>
    </choice>
    <choice id="ai.agentshore.cli"
            title="AgentShore CLI"
            description="Installs the 'agentshore' command in ~/.local/bin for headless and TUI sessions. Bootstraps uv via the official installer if it isn't already on this Mac."
            start_selected="true">
        <pkg-ref id="ai.agentshore.cli"/>
    </choice>
    <pkg-ref id="ai.agentshore.desktop"
             version="@VERSION@"
             onConclusion="none"
             auth="Root">@APP_COMPONENT_PKG@</pkg-ref>
    <pkg-ref id="ai.agentshore.timelapse"
             version="@VERSION@"
             onConclusion="none"
             auth="Root">@TIMELAPSE_COMPONENT_PKG@</pkg-ref>
    <pkg-ref id="ai.agentshore.cli"
             version="@VERSION@"
             onConclusion="none"
             auth="Root">@CLI_COMPONENT_PKG@</pkg-ref>
</installer-gui-script>
