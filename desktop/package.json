{
  "name": "agentshore-desktop",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm --prefix ../dashboard run build:lib",
    "build": "tsc && vite build",
    "prepare:tauri-assets": "node scripts/prepare-tauri-assets.mjs",
    "prebuild:tauri-frontend": "npm --prefix ../dashboard run build:lib",
    "build:tauri-frontend": "npm run build && npm run prepare:tauri-assets",
    "build:tauri-sidecars": "uv run python ../packaging/desktop/build_bd_sidecar.py --out src-tauri/binaries",
    "preview": "vite preview",
    "tauri": "tauri",
    "pretest": "npm --prefix ../dashboard run build:lib",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@agentshore/dashboard": "*",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
