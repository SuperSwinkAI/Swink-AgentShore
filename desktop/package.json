{
  "name": "agentshore-desktop",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm --prefix ../dashboard run build:lib",
    "build": "tsc && vite build",
    "prepare:tauri-assets": "node scripts/prepare-tauri-assets.mjs",
    "prebuild:tauri-frontend": "npm --prefix ../dashboard run build:lib",
    "build:tauri-frontend": "npm run build && npm run prepare:tauri-assets",
    "build:tauri-sidecars": "uv run python ../packaging/desktop/build_bd_sidecar.py --out src-tauri/binaries",
    "preview": "vite preview",
    "tauri": "tauri",
    "pretest": "npm --prefix ../dashboard run build:lib",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@agentshore/dashboard": "*",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.19.19",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "27.4.0",
    "typescript": "5.9.3",
    "vite": "8.0.13",
    "vitest": "4.1.6"
  }
}
